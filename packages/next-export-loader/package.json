{
  "name": "next-export-loader",
  "version": "0.1.0",
  "description": "Server-like loader lifecycle for Next.js Pages Router + output: 'export'",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./eslint-plugin": {
      "import": "./dist/eslint-plugin.js",
      "require": "./dist/eslint-plugin.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "next": ">=13",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "next.js",
    "pages-router",
    "static-export",
    "loader",
    "tanstack-query"
  ],
  "license": "MIT"
}
